import Config

# config/dev.secret.exs is OPTIONAL. The demo build defaults every AI
# feature to local Ollama (see config/dev.exs) and needs no API key.
#
# Copy this file to config/dev.secret.exs and uncomment a block only
# to point an AI feature at a cloud provider. Example — run the Lotus
# dashboard's SQL copilot on Gemini instead of Ollama:
#
#   config :lotus, :ai,
#     enabled: true,
#     model:   "google:gemini-2.5-flash",
#     api_key: System.fetch_env!("GOOGLE_API_KEY")
