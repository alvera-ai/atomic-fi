# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ephemeral bench working state — sharded NDJSON inputs + per-source
# subprocess proofs that get folded into the single committed report
# under benchmarks/. Regenerated from a fixed RNG seed on every run.
/.bench-work/

# Ignore package tarball (built via "mix hex.build").
phoenix_template_server-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# pnpm workspace
node_modules/
.pnpm-store/

# Per-runId integration-test state — never commit.
/integration-tests/vitest-state/

# Bootstrap credentials dumped by `mix atomic_fi.dump_bootstrap_creds` for E2E tests.
/priv/repo/.bootstrap_creds.json

# Local IDE / tooling caches — keep .claude/ tracked (intentional), ignore the rest.
/.vscode/
/.playwright-cli/
# Per-session runtime lock from Claude's scheduled-task harness — pid + sessionId.
/.claude/scheduled_tasks.lock

# Dev secrets (API keys) — never commit.
/config/dev.secret.exs

# Local test overrides (LLM transport → Ollama). No secrets, but
# per-developer — not committed.
/config/test.secret.exs

# macOS Finder metadata.
**/.DS_Store

# Example-app Vite build output — produced by `make server` watchers
# into priv/static/demo/<app>/, served by Plug.Static. Each example
# app's source lives under example-apps/<app>/; the dist is throwaway.
/priv/static/demo/onboarding-flow/
/priv/static/demo/atomic-fi-jdm-editor/
/priv/static/demo/lotus-embed/

# Example-app local dev secrets (Vite reads .env files).
/example-apps/*/.env
/example-apps/*/.env.local

# Playwright run artefacts (screenshots, traces) — regenerated per run.
/example-apps/*/test-results/
/example-apps/*/playwright-report/

