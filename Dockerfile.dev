FROM hexpm/elixir:1.18.3-erlang-27.3.3-debian-bookworm-20250428-slim

RUN apt-get update && apt-get install -y \
    git curl build-essential inotify-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY mix.exs mix.lock ./
RUN mix local.hex --force && mix local.rebar --force && mix deps.get

COPY config config
RUN mix deps.compile

COPY lib lib
COPY priv priv
COPY zen_rules zen_rules
COPY corpus corpus
COPY Makefile Makefile
COPY custom-watchlist.jsonl custom-watchlist.jsonl
COPY config.all-lists.yml config.all-lists.yml

RUN make hydrate-zen-rules 2>/dev/null || true
RUN mix compile

EXPOSE 4100

CMD ["sh", "-c", "mix ecto.setup && mix phx.server"]
