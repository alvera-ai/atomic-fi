# Lotus AI — model and API key for the embedded SQL copilot.
LOTUS_AI_MODEL=google:gemini-2.5-flash
LOTUS_AI_API_KEY=your-api-key-here

# CopilotKit runtime — AI sidebar in the JDM rule editor.
# Overrides external-deps/copilot-runtime/docker.env defaults (ollama).
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your-api-key-here
