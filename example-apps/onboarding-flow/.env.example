# API Configuration for M1 AccountHolder Onboarding
#
# Get these values after bootstrapping the backend:
#   mix ecto.setup && mix atomic_fi.dump_bootstrap_creds
#
# rootApiKey   → VITE_API_KEY
# tenant id    → VITE_TENANT_ID (get via POST /api/sessions or DB)
#
# The Vite dev server proxies /api → http://localhost:4100 automatically.

VITE_API_KEY=
VITE_TENANT_ID=
