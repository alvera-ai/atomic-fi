{
  "name": "@atomic-fi/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript SDK for the AtomicFi API. Generated from spec/openapi.yaml (which is itself generated by `mix openapi.spec.yaml`).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./generated/sdk.gen.ts",
    "./types": "./generated/types.gen.ts"
  },
  "scripts": {
    "spec:gen": "tsx scripts/generate-spec.ts",
    "sdk:gen": "openapi-ts",
    "build": "pnpm spec:gen && pnpm sdk:gen",
    "version:sync": "tsx scripts/sync-version.ts",
    "version:check": "tsx scripts/sync-version.ts --check",
    "check": "pnpm version:check && tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.7.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "valibot": "^1.2.0"
  }
}
