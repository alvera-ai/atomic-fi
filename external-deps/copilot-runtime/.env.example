# copilot-runtime — environment template. Copy to .env.local for non-Docker
# local dev (bun auto-loads .env.local). The Docker service reads docker.env.

# Provider toggle: openai | anthropic | google | groq | ollama | compatible
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:9b

# Ollama (LLM_PROVIDER=ollama) — optional; defaults to http://localhost:11434/api
# OLLAMA_BASE_URL=http://localhost:11434/api

# OpenAI-compatible fallback (LLM_PROVIDER=compatible) — vLLM, LM Studio,
# LiteLLM, or Ollama's own /v1.
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_COMPATIBLE_NAME=

# Native cloud providers — set the key matching LLM_PROVIDER.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

PORT=4111
# LOG_LEVEL=debug
