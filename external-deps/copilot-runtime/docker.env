# copilot-runtime behaviour — read by the Docker service in
# local-dependencies.yaml (env_file). Edit, then `docker compose up -d` again
# to change provider/model — no rebuild. The committed default targets local
# Ollama and carries no secret.

# Provider toggle: openai | anthropic | google | groq | ollama | compatible
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:9b

# host.docker.internal reaches Ollama on the host from inside the container.
OLLAMA_BASE_URL=http://host.docker.internal:11434/api

# CopilotKit telemetry → the copilot-telemetry Vector sidecar (same compose
# network) instead of telemetry.copilotkit.ai. See ADR-002 / vector.yaml.
COPILOTKIT_TELEMETRY_URL=http://copilot-telemetry:8686/ingest

PORT=4111
# LOG_LEVEL=debug
