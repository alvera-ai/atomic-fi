<!DOCTYPE html>
<html>
  <head>
    <title>API Documentation - Scalar</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <div id="scalar-app"></div>
    
<!-- Scalar API Reference from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@scalar/api-reference">
    </script>

    <script>
      // Initialize Scalar with our OpenAPI spec
      Scalar.createApiReference('#scalar-app', {
        url: '<%= @spec_url %>',
        theme: 'default',
      })
    </script>
  </body>
</html>
