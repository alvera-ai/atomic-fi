meta {
  name: 009 — Create clean recipient payment account
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/payment-accounts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authBearer}}
}

headers {
  content-type: application/json
  accept: application/json
}

script:pre-request {
  bru.setVar("externalId", `DTTOT-PA-CLEAN-RECIP-${Date.now()}-${Math.floor(Math.random() * 1e6)}`);
}

body:json {
  {
    "external_id": "{{externalId}}",
    "account_type": "wallet",
    "currency": "USD",
    "account_holder_id": "{{cleanRecipientAhId}}",
    "tenant_id": "{{tenantId}}"
  }
}

script:post-response {
  bru.setEnvVar("cleanRecipientPaId", res.body.id);
}

assert {
  res.status: eq 201
}
