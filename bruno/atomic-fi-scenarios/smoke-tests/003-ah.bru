meta {
  name: 003 — Create account holder (with nested legal entity)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/account-holders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authBearer}}
}

headers {
  content-type: application/json
  accept: application/json
}

script:pre-request {
  const year  = 1960 + Math.floor(Math.random() * 40);
  const month = String(1 + Math.floor(Math.random() * 12)).padStart(2, "0");
  const day   = String(1 + Math.floor(Math.random() * 28)).padStart(2, "0");
  bru.setVar("dob", `${year}-${month}-${day}`);
}

body:json {
  {
    "holder_type": "individual",
    "status": "active",
    "kyc_status": "approved",
    "risk_level": "low",
    "enabled_currencies": ["USD"],
    "chain_screening": false,
    "legal_entity": {
      "legal_entity_type": "individual",
      "first_name": "{{$randomFirstName}}",
      "last_name": "{{$randomLastName}}",
      "date_of_birth": "{{dob}}",
      "citizenship_country": "US",
      "politically_exposed_person": false,
      "tenant_id": "{{tenantId}}"
    },
    "tenant_id": "{{tenantId}}"
  }
}

script:post-response {
  const ahIds = JSON.parse(bru.getEnvVar("ahIds") || "[]");
  ahIds.push(res.body.id);
  bru.setEnvVar("ahIds", JSON.stringify(ahIds));
}

assert {
  res.status: eq 201
  res.body.id: matches ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$
  res.body.kyc_status: eq approved
}
