meta {
  name: 006 — Create PEP sender payment account (USD)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/payment-accounts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authBearer}}
}

headers {
  content-type: application/json
  accept: application/json
}

script:pre-request {
  bru.setVar("externalId", `IDPEP-PA-PEP-${Date.now()}-${Math.floor(Math.random() * 1e6)}`);
}

body:json {
  {
    "external_id": "{{externalId}}",
    "account_type": "bank_account",
    "currency": "USD",
    "account_holder_id": "{{pepSenderAhId}}",
    "tenant_id": "{{tenantId}}"
  }
}

script:post-response {
  bru.setEnvVar("pepSenderPaId", res.body.id);
}

assert {
  res.status: eq 201
}
